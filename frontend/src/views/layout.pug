doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title #{title} | Asset Management System
    
    //- Google Fonts
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet")
    
    //- FontAwesome Icons
    link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css")
    
    //- Bootstrap 5 CSS
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet")
    
    //- DataTables Bootstrap 5 CSS
    link(href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css" rel="stylesheet")
    
    //- Custom CSS
    link(rel="stylesheet" href="/css/style.css")
  
  body
    #wrapper.d-flex
      //- Sidebar
      #sidebar-wrapper.border-end.bg-white
        .sidebar-heading.text-center.py-4.fs-4.fw-bold.text-uppercase.border-bottom
          i.fa-solid.fa-boxes-packing.me-2.text-primary
          span.text-primary Asset
          span.text-dark Mgt
        .list-group.list-group-flush.my-3.px-2
          a.list-group-item.list-group-item-action.bg-transparent.py-2.px-3.rounded.border-0.mb-1(href="/" class=activePage === 'dashboard' ? 'active-sidebar' : '')
            i.fa-solid.fa-chart-pie.me-2
            | Stock View
          a.list-group-item.list-group-item-action.bg-transparent.py-2.px-3.rounded.border-0.mb-1(href="/employees" class=activePage === 'employees' ? 'active-sidebar' : '')
            i.fa-solid.fa-users.me-2
            | Employee Master
          a.list-group-item.list-group-item-action.bg-transparent.py-2.px-3.rounded.border-0.mb-1(href="/categories" class=activePage === 'categories' ? 'active-sidebar' : '')
            i.fa-solid.fa-tags.me-2
            | Category Master
          a.list-group-item.list-group-item-action.bg-transparent.py-2.px-3.rounded.border-0.mb-1(href="/assets" class=activePage === 'assets' ? 'active-sidebar' : '')
            i.fa-solid.fa-laptop.me-2
            | Asset Master
            
          //- Collapsible Operations
          a.list-group-item.list-group-item-action.bg-transparent.py-2.px-3.rounded.border-0.mb-1.d-flex.justify-content-between.align-items-center(data-bs-toggle="collapse" href="#operationsCollapse" role="button" aria-expanded=(['issue', 'return', 'scrap'].includes(activePage)) ? 'true' : 'false' aria-controls="operationsCollapse")
            span
              i.fa-solid.fa-handshake.me-2
              | Operations
            i.fa-solid.fa-chevron-down.text-xs.transition-icon
          .collapse#operationsCollapse(class=(['issue', 'return', 'scrap'].includes(activePage)) ? 'show' : '')
            .ps-3.mt-1
              a.list-group-item.list-group-item-action.bg-transparent.py-2.px-3.rounded.border-0.mb-1(href="/issue" class=activePage === 'issue' ? 'active-sidebar' : '')
                i.fa-solid.fa-arrow-right-from-bracket.me-2.text-primary
                | Issue Asset
              a.list-group-item.list-group-item-action.bg-transparent.py-2.px-3.rounded.border-0.mb-1(href="/return" class=activePage === 'return' ? 'active-sidebar' : '')
                i.fa-solid.fa-arrow-right-to-bracket.me-2.text-success
                | Return Asset
              a.list-group-item.list-group-item-action.bg-transparent.py-2.px-3.rounded.border-0.mb-1(href="/scrap" class=activePage === 'scrap' ? 'active-sidebar' : '')
                i.fa-solid.fa-trash-can.me-2.text-danger
                | Scrap Asset

          a.list-group-item.list-group-item-action.bg-transparent.py-2.px-3.rounded.border-0.mb-1(href="/history" class=activePage === 'history' ? 'active-sidebar' : '')
            i.fa-solid.fa-clock-rotate-left.me-2
            | Asset History

      //- Page Content
      #page-content-wrapper
        nav.navbar.navbar-expand-lg.navbar-light.bg-white.py-2.px-4.border-bottom
          .container-fluid.p-0
            button.btn.btn-outline-secondary.border-0#menu-toggle(type="button")
              i.fa-solid.fa-bars
            .d-flex.align-items-center.ms-auto
              span.fw-semibold.text-muted Asset Admin Dashboard

        .container-fluid.px-4.py-4
          #toast-container.position-fixed.bottom-0.end-0.p-3(style="z-index: 1080")
          block content

    //- jQuery (required for DataTables)
    script(src="https://code.jquery.com/jquery-3.6.4.min.js")
    
    //- Bootstrap 5 Bundle JS
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    
    //- DataTables JS
    script(src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js")
    script(src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js")
    
    //- Bridge Express backend URL config to browser JS
    script.
      window.BACKEND_API_URL = "!{backendApiUrl}";
      
    //- App custom JS
    script(src="/js/apiClient.js")
    script(src="/js/main.js")
