extends ../layout

block content
  .row.mb-4
    .col-12
      h1.h3.mb-0.text-gray-800
        i.fa-solid.fa-clock-rotate-left.me-2.text-primary
        | Asset History Timeline
      p.text-muted Trace the complete lifecycle of a corporate asset from initial purchase to decommissioning.

  .row.mb-4
    .col-lg-5
      .card.shadow-sm
        .card-header.bg-white.py-3
          h6.m-0.font-weight-bold.text-primary
            i.fa-solid.fa-magnifying-glass.me-2
            | Find Asset
        .card-body.p-4
          form#search-history-form
            .mb-3
              label.form-label.fw-bold(for="history-asset-select") Select Asset *
              select.form-select.form-select-lg#history-asset-select(required)
                option(value="" disabled selected) Loading all assets (including scraped)...
              .form-text.text-muted Search by asset code, serial number.
            .d-grid
              button.btn.btn-primary.btn-lg(type="submit")
                i.fa-solid.fa-binoculars.me-2
                | Load History Timeline

          //- Selected Asset Summary Info Card
          #history-asset-info.mt-4.d-none
            hr
            h6.fw-bold.text-secondary.text-uppercase.text-xs Asset Summary Details
            table.table.table-sm.table-borderless.mb-0.align-middle
              tr
                td.text-muted Code:
                td.fw-bold#info-code --
              tr
                td.text-muted Serial:
                td#info-serial --
              tr
                td.text-muted Category:
                td#info-category --
              tr
                td.text-muted Make/Model:
                td#info-model --
              tr
                td.text-muted Current Status:
                td#info-status --

    .col-lg-7
      .card.shadow-sm.h-100
        .card-header.bg-white.py-3
          h6.m-0.font-weight-bold.text-primary
            i.fa-solid.fa-timeline.me-2
            | Operational History Timeline
        .card-body.p-4
          //- Empty state
          #timeline-empty.text-center.py-5
            i.fa-solid.fa-diagram-project.fa-3x.text-gray-300.mb-3
            h6.text-muted Choose an asset on the left to display its movements.

          //- Timeline list
          #timeline-container.timeline.d-none
            //- Timeline items will be injected here dynamically
